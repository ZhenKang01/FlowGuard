    {
      "id": "7788aabb-ccdd-eeff-0011-223344556677",
      "name": "HITL Ethics Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [1100, 640],
      "parameters": {
        "content": "## ⚠️ Human-in-the-Loop\n\nThis branch **recommends** — it does **not** execute.\n\n`needs_approval: true` + `status: pending_approval` tells FastAPI and the React dashboard that this alert requires sign-off.\n\nThe operator clicks **Approve** in the dashboard → `PATCH /alerts/{id}/approve` is called → status becomes `approved`.\n\nNo physical action (valve shutoff, etc.) is auto-executed by this workflow.",
        "height": 210,
        "width": 400,
        "color": 4
      }
    }

