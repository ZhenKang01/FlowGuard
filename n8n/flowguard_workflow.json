{
  "name": "FlowGuard — Anomaly Router",
  "nodes": [

    {
      "id": "aa11bb22-cc33-dd44-ee55-ff6677889900",
      "name": "Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [60, 60],
      "parameters": {
        "content": "## FlowGuard Anomaly Router\n\nReceives a POST from FastAPI `/score` whenever the LSTM model flags a meter.\n\n**Routing:**\n- `low` or `medium` → formatted as `status: active` → POST `/alerts`\n- `high` → formatted as `status: pending_approval`, `needs_approval: true` → POST `/alerts`\n\nThe React dashboard polls `/alerts` every 5 s.\nHigh-severity alerts show an **Approve** button — a human must click it.\nn8n only **recommends**; it never executes the shutoff.",
        "height": 240,
        "width": 520,
        "color": 3
      }
    },

    {
      "id": "11223344-5566-7788-99aa-bbccddeeff00",
      "name": "FlowGuard Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [640, 320],
      "webhookId": "f10wg4rd-an0m-4ly-w3bh-00k000000001",
      "parameters": {
        "httpMethod": "POST",
        "path": "flowguard-anomaly",
        "responseMode": "onReceived",
        "responseData": "noData",
        "options": {}
      }
    },

    {
      "id": "22334455-6677-8899-aabb-ccddeeff0011",
      "name": "Route by Severity",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [880, 320],
      "parameters": {
        "mode": "rules",
        "options": {},
        "rules": {
          "rules": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "rule-low",
                    "leftValue": "={{ $json.severity }}",
                    "rightValue": "low",
                    "operator": {
                      "type": "string",
                      "operation": "equals",
                      "name": "filter.operator.equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "low"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "rule-medium",
                    "leftValue": "={{ $json.severity }}",
                    "rightValue": "medium",
                    "operator": {
                      "type": "string",
                      "operation": "equals",
                      "name": "filter.operator.equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "medium"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "rule-high",
                    "leftValue": "={{ $json.severity }}",
                    "rightValue": "high",
                    "operator": {
                      "type": "string",
                      "operation": "equals",
                      "name": "filter.operator.equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "high"
            }
          ]
        }
      }
    },

