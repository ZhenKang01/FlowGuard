# ── Supabase (React / Vite frontend) ─────────────────────────────────────────
# Required: copy from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── FastAPI base URL (React / Vite frontend) ──────────────────────────────────
# Where the anomaly_detection FastAPI service is running.
# Default: http://localhost:8000 — only set this if you change the port.
VITE_FLOWGUARD_API_URL=http://localhost:8000


# ── LLM provider (FastAPI server — NOT bundled into the frontend build) ───────
#
# Provider: OpenAI  (used for chat completions + embeddings)
#   Install: pip install openai>=1.30.0
#   Sign up:  https://platform.openai.com/api-keys
#
OPENAI_API_KEY=sk-...your-openai-key-here...
OPENAI_CHAT_MODEL=gpt-4o-mini         # or gpt-4o, gpt-3.5-turbo
OPENAI_EMBED_MODEL=text-embedding-3-small


# ── n8n webhook (FastAPI server — optional) ───────────────────────────────────
# If n8n is not running, /score still works; the notification is just skipped.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/flowguard-anomaly


# ── Supabase service role key (FastAPI server — for work-order writes) ────────
# This is the SERVICE ROLE key (not the anon key) — keep it server-side only.
# Find it: Supabase → Settings → API → service_role secret
# If not set, the chatbot will log the work order locally and skip the DB write.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
